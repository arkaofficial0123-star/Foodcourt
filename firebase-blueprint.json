{
  "entities": {
    "Restaurant": {
      "title": "Restaurant",
      "description": "A restaurant tenant instance",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique URL slug for the restaurant"
        },
        "name": {
          "type": "string",
          "description": "Name of the restaurant"
        },
        "password": {
          "type": "string",
          "description": "Local staff/admin entry password"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp indicating when restaurant tenant was registered"
        }
      },
      "required": ["id", "name", "password", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "A restaurant menu item/dish",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the menu item"
        },
        "name": {
          "type": "string",
          "description": "Name of the dish"
        },
        "price": {
          "type": "number",
          "description": "Price of the dish"
        },
        "imageUrl": {
          "type": "string",
          "description": "Image URL or Base64 representation of the dish"
        },
        "categoryId": {
          "type": "string",
          "description": "Optional identifier of the category"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO structure or Firebase timestamp indicating when item was added"
        }
      },
      "required": ["name", "price", "imageUrl", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A food category",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the category"
        },
        "name": {
          "type": "string",
          "description": "Name of the category"
        },
        "imageUrl": {
          "type": "string",
          "description": "Image URL of the category"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp indicating when category was added"
        }
      },
      "required": ["name", "imageUrl", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a specific table",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the order"
        },
        "tableId": {
          "type": "string",
          "description": "Identifier of the table placing the order"
        },
        "items": {
          "type": "array",
          "description": "List of ordered items with quantities and snapshot details"
        },
        "total": {
          "type": "number",
          "description": "Total order amount"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "completed"],
          "description": "Current preparation state of the order"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the order was placed"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the order status was last updated"
        }
      },
      "required": ["tableId", "items", "total", "status", "createdAt", "updatedAt"]
    },
    "Banner": {
      "title": "Banner",
      "description": "A singleton representing promotional banner configuration",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "Promotional or welcome text description"
        },
        "imageUrl": {
          "type": "string",
          "description": "Banner background image URL or Base64 representation"
        },
        "visible": {
          "type": "boolean",
          "description": "Controls whether the banner is shown to clients"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp for the last banner modification"
        }
      },
      "required": ["text", "imageUrl", "visible", "updatedAt"]
    }
  },
  "firestore": {
    "/restaurants/{restaurantId}": {
      "schema": "Restaurant",
      "description": "Registered restaurant instances"
    },
    "/restaurants/{restaurantId}/items/{itemId}": {
      "schema": "Item",
      "description": "Tenant specific menu items"
    },
    "/restaurants/{restaurantId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Tenant specific active and completed orders"
    },
    "/restaurants/{restaurantId}/settings/banner": {
      "schema": "Banner",
      "description": "Tenant specific banner configuration"
    },
    "/restaurants/{restaurantId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "Tenant specific categories"
    }
  }
}
